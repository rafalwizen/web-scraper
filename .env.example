# Email scraper configuration for panoramafirm.pl

# Keyword to append to URL
SEARCH_CATEGORY=fryzjerzy_i_salony_fryzjerskie

# Base URL (usually doesn't need to be changed)
BASE_URL=https://panoramafirm.pl

# Output file name
OUTPUT_FILE=emails.txt

# Delay between requests in seconds (to not overload server)
DELAY=1.0
